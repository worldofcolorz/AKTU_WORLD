GOOGLE_AI_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
DRIVE_CACHE_MAX_MB=800
DRIVE_TREE_CACHE_TTL_SECONDS=900
# Where the visit counter is persisted - defaults to a temp file if unset
VISIT_COUNTER_FILE=
# Where downloaded Drive files are cached on disk - defaults to a
# drive_cache/ folder next to VISIT_COUNTER_FILE (or the cwd) if unset
DRIVE_CACHE_DIR=
# Comma-separated list of origins allowed to call this API - defaults to the
# production frontend + local Vite dev server if unset
ALLOWED_ORIGINS=
